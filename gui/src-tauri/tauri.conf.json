{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jobowalls-gui",
  "version": "0.1.3",
  "identifier": "dev.jobowalls.picker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "jobowalls-picker",
        "width": 1040,
        "height": 620,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "alwaysOnTop": false,
        "visibleOnAllWorkspaces": false,
        "skipTaskbar": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../../assets/test/static-test.png"]
  }
}
